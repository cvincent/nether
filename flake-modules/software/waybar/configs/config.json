{
  "reload_style_on_change": true,
  "layer": "top", // Waybar at top layer
  "position": "bottom", // Waybar position (top|bottom|left|right)
  "height": 36, // Waybar height (to be removed for auto height)
  // "width": 1280, // Waybar width
  "spacing": 0, // Gaps between modules (4px)

  "modules-left": ["hyprland/workspaces", "mpris"],
  "modules-center": ["custom/window", "privacy", "hyprland/submap"],
  "modules-right": [
    "idle_inhibitor",
    "network",
    "pulseaudio",
    "cpu",
    "memory",
    "battery",
    "clock",
    "custom/weather",
    "custom/mail",
    "tray",
    "custom/notification"
  ],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "on-click": "activate",
    "sort-by-number": true,
    "format": "{icon}",
    "format-icons": {
      "1": "’¬×",
      "2": "’é▒",
      "3": "’äĀ",
      "4": "’äĪ",
      "5": "¾░Ł╣",
      "6": "’ć¬",
      "8": "ŅŁŻ",
      "7": "’Ćł",
      "9": "¾░Ā«",
      "10": "’åĘ"
    }
  },

  "mpris": {
    "player": "playerctld",
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "dynamic-order": ["title", "artist", "position", "length"],
    "player-icons": {
      "default": "¾░ÉŖ",
      "mpv": "­¤ÄĄ"
    },
    "status-icons": {
      "paused": "¾░Åż"
    },
    "interval": 1
    // "ignored-players": ["firefox"]
  },

  "custom/window": {
    "max-length": 200,
    "return-type": "json",
    "hide-empty-text": true,
    "separate-outputs": true,
    "on-click": "hyprctl dispatch changegroupactive f",
    "on-click-right": "hyprctl dispatch changegroupactive b",
    "rewrite": {
      "(.*) - qutebrowser": "$1"
    }
  },

  "privacy": {
    "icon-spacing": 16,
    "icon-size": 16,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 16
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 16
      }
    ],
    "ignore-monitor": false,
    "ignore": []
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ŅØæ",
      "deactivated": "’łČ"
    },
    "tooltip": false
  },

  "network": {
    // "interface": "wlp2*", // (Optional) To force the use of this interface
    "format-wifi": "’ć½",
    "format-ethernet": "{ipaddr}/{cidr}",
    "tooltip-format": "{essid} {ipaddr} ({signalStrength}%)",
    "format-linked": "{ifname} (No IP)",
    "format-disconnected": "ŌÜĀ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },

  "pulseaudio": {
    "scroll-step": 5, // %, can be a float
    "format": "{format_source} {icon} {volume}%",
    "format-bluetooth": "{format_source} {icon}’Ŗö {volume}%",
    "format-bluetooth-muted": "{icon}’Ŗö {format_source}",
    "format-muted": "’¬Ć {format_source}",
    "format-source": "’ä░",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "headphone": "’Ćź",
      "hands-free": "¾░ŗÄ",
      "headset": "¾░ŗÄ",
      "phone": "’éĢ",
      "portable": "’éĢ",
      "car": "’å╣",
      "default": ["’Ć”", "’Ć¦", "’Ć©"]
    },
    "on-click": "pavucontrol"
  },

  "cpu": {
    "format": "’Æ╝ {usage}%",
    "tooltip": false
  },

  "memory": {
    "format": "’ŗø {}%",
    "tooltip-format": "{used} / {total}G"
  },

  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "’Ś¦ {capacity}%",
    "format-plugged": "’ć” {capacity}%",
    "format-alt": "{icon} {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
  },

  "clock": {
    // "timezone": "America/New_York",
    "format": "’ĆŚ {:%a %b %d %I:%M %p}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
  },

  "custom/weather": {
    "exec": "~/bin/waybar-weather.py",
    "return-type": "json"
  },

  "custom/mail": {
    "format": "’É» {text}",
    "return-type": "json",
    "interval": 2
  },

  "tray": {
    // "icon-size": 21,
    "spacing": 10
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "none": "’éó",
      "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-none": "’ćĘ",
      "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "inhibited-none": "’éó",
      "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-inhibited-none": "’ćĘ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  // Unused modules

  "temperature": {
    // "thermal-zone": 2,
    // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    // "format-critical": "{temperatureC}┬░C {icon}",
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["’Ø½", "’ŗē", "’Ø®"]
  },

  "backlight": {
    // "device": "acpi_video1",
    "format": "{percent}% {icon}",
    "format-icons": ["ŅÄŹ", "ŅÅō", "ŅÅæ", "ŅÅÅ", "ŅÅÄ", "ŅÅŹ", "ŅÅŖ", "ŅÅł", "ŅÄø"]
  },

  "custom/media": {
    "format": "{icon} {}",
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "’å╝",
      "default": "­¤Ä£"
    },
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
    // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
  },
}
